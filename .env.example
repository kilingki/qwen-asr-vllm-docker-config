ASR_API_PORT=8080

MODEL_HOST_DIR=../models/stt/hf

ASR_MODEL_PATH=/models/Qwen3-ASR-1.7B
ASR_MODEL=qwen3-asr
QWEN_ASR_INTERNAL_HOST=127.0.0.1
QWEN_ASR_INTERNAL_PORT=18000
ASR_BASE_URL=http://127.0.0.1:18000/v1

ASR_GPU_MEMORY_UTILIZATION=0.72
ASR_MAX_MODEL_LEN=10000
ASR_GENERATION_CONFIG=vllm

DEFAULT_LANGUAGE=ko
CHUNK_SECONDS=120
CHUNK_OVERLAP_SECONDS=2
REQUEST_TIMEOUT_SECONDS=600

LOG_LEVEL=info

# Optional settings for scripts/test_qwen_asr_youtube.py
STT_BASE_URL=http://localhost:8080
STT_MODEL=qwen3-asr
STT_RESPONSE_FORMAT=verbose_json
STT_TIMESTAMP_GRANULARITIES=segment
STT_HEALTH_RETRIES=30
STT_HEALTH_BACKOFF_SEC=2
STT_REQUEST_TIMEOUT_SECONDS=7200
STT_OUTPUT_DIR=./scripts/outputs
